# SceneExpert runtime configuration template.
# Copy this file to .env and edit the values for your server:
#
#   cp .env.example .env
#   vim .env
#
# Copying/editing .env does not load it into your current terminal. If you want
# to inspect variables with echo before running a script, source it manually:
#
#   source .env
#   echo "$SCENEEXPERT_MODEL_ID"
#
# Project scripts automatically source .env from the project root. To use a
# different file, run:
#
#   SCENEEXPERT_ENV_FILE=/path/to/sceneexpert.env bash scripts/run_experiment.sh ablation_4_qwen3_harness_memory

# ---------------------------------------------------------------------------
# Python environment
# ---------------------------------------------------------------------------

# run_experiment.sh activates the project .venv by default. Set this to 0 when
# you already activated a Conda environment or another venv that contains all
# dependencies, including vLLM.
export SCENEEXPERT_ACTIVATE_VENV=1
export SCENEEXPERT_VENV_PATH=".venv"

# ---------------------------------------------------------------------------
# Local LLM / vLLM
# ---------------------------------------------------------------------------

export SCENEEXPERT_MODEL_ID="Qwen/Qwen3.5-35B-A3B"
export SCENEEXPERT_MODELS_DIR="/mnt/afs/task3_2/L202500276_lwz/models"
export SCENEEXPERT_MODEL_DIR="/mnt/afs/task3_2/L202500276_lwz/models/Qwen3.5-35B-A3B"

export SCENEEXPERT_VLLM_PORT=8000
export SCENEEXPERT_VLLM_HEALTH_URL="http://localhost:8000/health"

# Single-GPU bootstrap defaults. Unquantized 35B MoE may still require CPU
# offload or a quantized checkpoint on one GPU; 2+ 80GB GPUs are recommended.
export SCENEEXPERT_TENSOR_PARALLEL_SIZE=1
export SCENEEXPERT_MAX_MODEL_LEN=32768
export SCENEEXPERT_GPU_MEMORY_UTILIZATION=0.90
export SCENEEXPERT_GPU_PREFLIGHT_CHECK=1
export SCENEEXPERT_VLLM_DTYPE="auto"
export SCENEEXPERT_VLLM_QUANTIZATION=""
export SCENEEXPERT_VLLM_CPU_OFFLOAD_GB=20
export SCENEEXPERT_VLLM_KV_CACHE_DTYPE="auto"
export SCENEEXPERT_VLLM_WAIT_TIMEOUT_SECONDS=5400
export SCENEEXPERT_VLLM_ENGINE_READY_TIMEOUT_S=5400
export SCENEEXPERT_VLLM_SAFETENSORS_LOAD_STRATEGY="prefetch"
export SCENEEXPERT_VLLM_USE_DEEP_GEMM=0
export SCENEEXPERT_VLLM_MOE_USE_DEEP_GEMM=0
export SCENEEXPERT_VLLM_DEEP_GEMM_WARMUP="skip"
export SCENEEXPERT_VLLM_ENFORCE_EAGER=1

# Fast HSSD-only reproduction. Set to 0 only after artvip_sdf or
# partnet_mobility_sdf has been prepared under writable SCENEEXPERT_DATA_DIR.
# See README_CN.md for ArtVIP/PartNet download and embedding steps.
export SCENEEXPERT_DISABLE_ARTICULATED=1

# Fast HSSD-only reproduction. Set to 0 only after materials/ and
# materials/embeddings/ have been prepared under writable SCENEEXPERT_DATA_DIR.
# See README_CN.md for AmbientCG materials download and embedding steps.
export SCENEEXPERT_DISABLE_MATERIALS=1

# ConvexDecompositionServer is used by furniture/wall/ceiling/manipuland stages
# to generate collision geometry. Large ACP nodes may otherwise use 100+ OpenMP
# threads and hit a false 10s startup timeout.
export SCENEEXPERT_CONVEX_READY_TIMEOUT=120
export SCENEEXPERT_CONVEX_MAX_OMP_THREADS=32

# Qwen3 defaults. Change these when serving another model family.
export SCENEEXPERT_ENABLE_AUTO_TOOL_CHOICE=1
export SCENEEXPERT_TOOL_CALL_PARSER="qwen3_xml"
export SCENEEXPERT_REASONING_PARSER="qwen3"

# Set to 0 only when another OpenAI-compatible local service is already running
# and run_experiment.sh should connect to it instead of starting vLLM.
export SCENEEXPERT_START_VLLM=1

# OpenAI-compatible endpoint exposed by local vLLM. The key is a dummy value for
# local services; no real OpenAI cloud key is required for local Qwen inference.
export OPENAI_API_KEY="not-needed"
export OPENAI_BASE_URL="http://localhost:8000/v1"

# ---------------------------------------------------------------------------
# Data, checkpoints, outputs
# ---------------------------------------------------------------------------

# Read-only HSSD/HSM asset root. This directory contains hssd-models/ and
# preprocessed/, and may not be writable on cluster compute nodes.
export SCENEEXPERT_HSSD_DATA_DIR="/mnt/afs/task3_2/L202500276_lwz/data/hsm"

# Writable SceneExpert data root. Put optional/downloaded assets here:
# materials/, artvip_sdf/, partnet_mobility_sdf/, openclip/, etc.
export SCENEEXPERT_DATA_DIR="/mnt/afs/task3_2/L202500276_lwz/data"

# OpenCLIP is stored under the writable data root, separately from HSSD/HSM.
export SCENEEXPERT_OPENCLIP_DIR="${SCENEEXPERT_DATA_DIR}/openclip"
# This can point to the .bin file or to the model directory that contains
# open_clip_pytorch_model.bin.
export SCENEEXPERT_OPENCLIP_CHECKPOINT="${SCENEEXPERT_OPENCLIP_DIR}/DFN5B-CLIP-ViT-H-14-378/open_clip_pytorch_model.bin"
export SCENEEXPERT_REQUIRE_LOCAL_OPENCLIP=1
export SCENEEXPERT_CHECKPOINTS_DIR="/mnt/afs/task3_2/share_model/scenesmith/sam3d"
export SCENEEXPERT_OUTPUT_DIR="/mnt/afs/task3_2/L202500276_lwz/projects/SceneExpert/sceneexpert_outputs"
export SCENEEXPERT_MEMORY_DIR="${SCENEEXPERT_OUTPUT_DIR}/scene_expert_memory"

# ---------------------------------------------------------------------------
# SceneExpert memory embedding/index preparation
# ---------------------------------------------------------------------------

# Lexical retrieval is the safe default. After running scripts/build_memory_index.py,
# set SCENEEXPERT_MEMORY_RETRIEVER_TYPE=hybrid to use the local numpy vector index.
export SCENEEXPERT_MEMORY_RETRIEVER_TYPE="lexical"
export SCENEEXPERT_MEMORY_INDEX_BACKEND="numpy"
export SCENEEXPERT_MEMORY_INDEX_DIR=""
export SCENEEXPERT_MEMORY_RECALL_TOP_K=30
export SCENEEXPERT_MEMORY_SIM_THRESHOLD=0.0
export SCENEEXPERT_MEMORY_OBJECT_OVERLAP_THRESHOLD=0.15
# When retriever_type=hybrid, fail fast if non-empty memory banks have no index.
export SCENEEXPERT_MEMORY_INDEX_REQUIRE_READY=true

# model_id is metadata; actual loading must use the local model_dir below.
export SCENEEXPERT_MEMORY_EMBEDDING_MODEL_ID="BAAI/bge-m3"
export SCENEEXPERT_MEMORY_EMBEDDING_MODEL_DIR="${SCENEEXPERT_MODELS_DIR}/bge-m3"

# Online retrieval defaults to CPU so it does not compete with vLLM/OpenCLIP.
# Offline index building may use cuda if the job has spare GPU memory.
export SCENEEXPERT_MEMORY_EMBEDDING_DEVICE="cpu"
export SCENEEXPERT_MEMORY_EMBEDDING_INDEX_DEVICE="cpu"
export SCENEEXPERT_MEMORY_EMBEDDING_BATCH_SIZE=8
export SCENEEXPERT_MEMORY_EMBEDDING_MAX_LENGTH=512

# Optional: pip mirror used by deploy_qwen.sh when SCENEEXPERT_INSTALL_RUNTIME_DEPS=1.
export SCENEEXPERT_PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
